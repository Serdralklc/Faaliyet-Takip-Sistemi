generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SISTEM_ADMIN
  GENEL_MERKEZ
  TURKIYE_EGITIM_SORUMLUSU
  TURKIYE_UNIVERSITE_SORUMLUSU
  TURKIYE_LISE_SORUMLUSU
  TEKNIK              // Teknik destek / sistem talepleri rolü (sınırlı erişim)
  BOLGE_SORUMLUSU
  IL_SORUMLUSU
  BEKLEYEN
}

// Merkez Ekip (GENEL_MERKEZ) içinde görev ayrımı. Hepsi aynı ekran/yetkilere
// sahiptir; yalnızca İstişare/talep yönlendirmesi ve etiket için kullanılır.
// (Boş = düz "Merkez Ekibi".)
enum MerkezGorev {
  ILKOGRETIM
  LISE
  UNIVERSITE
  SEKRETERYA
}

// İstişare Merkezi (talep) birimi → hedef rol yönlendirmesi:
//  ILKOGRETIM/LISE/UNIVERSITE → GENEL_MERKEZ + ilgili merkezGorev
//  UNIVERSITE_GENCLIK → TURKIYE_UNIVERSITE_SORUMLUSU, LISE_GENCLIK → TURKIYE_LISE_SORUMLUSU
//  GENEL → Merkez Sekreterya (merkezGorev=SEKRETERYA), TEKNIK → role TEKNIK
enum TalepBirim {
  ILKOGRETIM
  LISE
  UNIVERSITE
  UNIVERSITE_GENCLIK
  LISE_GENCLIK
  GENEL
  TEKNIK
}

enum TalepDurum {
  YENI
  INCELENIYOR
  YANITLANDI
  COZULDU
  KAPATILDI
}

enum UserStatus {
  AKTIF
  BEKLEMEDE
  PASIF
}

enum AssignmentStatus {
  AKTIF
  TAMAMLANDI
}

enum Donem {
  DONEM_1
  DONEM_2
  YAZ_DONEMI
}

// Her kullanıcı hangi faaliyet takip sistemine ait olduğunu belirtir.
// Farklı sistemlere kayıtlı kullanıcılar birbirinin verilerini göremez.
enum Sistem {
  EGITIMCI   // Eğitimci Kadrosu — il/bölge sorumluları, yöneticiler
  UNIVERSITE // Üniversite Gençlik faaliyet takip sistemi
  LISE       // Lise Gençlik faaliyet takip sistemi
}

model User {
  id           String     @id @default(cuid())
  ad           String
  soyad        String
  email        String     @unique
  telefon      String?
  passwordHash String?
  role         Role       @default(BEKLEYEN)
  status       UserStatus @default(BEKLEMEDE)
  sistem       Sistem     @default(EGITIMCI)
  // Ek yardımcı rol (teşkilat rolü değildir): belirli Merkez Ekip üyelerine
  // içerik yönetimi yetkisi (Form Yönetimi, Bildirim, Muradımız, Doküman, Arşiv) verir
  icerikYoneticisi Boolean @default(false)
  // Yan rol: Teknik (İstişare'de teknik talepleri karşılar; ana rolden bağımsız ek yetki)
  teknikYetkisi Boolean @default(false)
  // Merkez Ekip görev ayrımı (yalnızca GENEL_MERKEZ için anlamlı; boş = düz Merkez Ekibi)
  // (F2 geçiş: yan rol tablosuna taşındı; bu alan uyum-köprüsü olarak senkron tutulur)
  merkezGorev  MerkezGorev?
  // F2: Ana Rol (yönetim paneli birincil rolü) — ayrı tablo. `role` alanı uyum köprüsü olarak senkron tutulur.
  anaRolId     String?
  // Kayıt sırasında başvurulan görev bilgisi (onay sürecinde admin görsün)
  basvuruGorev   String?
  basvuruBolgeId String?
  basvuruIlId    String?
  // Son giriş (aktiflik) zamanı — her başarılı girişte güncellenir
  sonAktif     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignments       RoleAssignment[]
  createdActivities Activity[]       @relation("CreatedBy")
  updatedActivities Activity[]       @relation("UpdatedBy")
  auditLogs         AuditLog[]       @relation("ActionBy")
  invitations       Invitation[]     @relation("InvitedBy")
  talepler          Talep[]          @relation("TalepOlusturan")
  talepMesajlari    TalepMesaj[]     @relation("TalepMesajGonderen")
  anaRol            AnaRol?          @relation(fields: [anaRolId], references: [id])
  yanRoller         UserYanRol[]
}

// ── F2: Ana Rol / Yan Rol ayrı tabloları ──────────────────────────────
// Ana Rol: yönetim paneli birincil rolü (kullanıcı başına TEK). Saha (bölge/il)
// ve bekleyen kullanıcılar role+sistem ile yönetilir; onlarda anaRolId boştur.
model AnaRol {
  id    String @id @default(cuid())
  kod   String @unique // ADMIN | MERKEZ | UNIVERSITE_GENCLIK | LISE_GENCLIK
  ad    String
  sira  Int    @default(0)
  users User[]
}

// Yan Rol: ek içerik/yetki rolleri (kullanıcı başına ÇOKLU). Katalog tablo.
model YanRol {
  id    String       @id @default(cuid())
  kod   String       @unique
  ad    String
  sira  Int          @default(0)
  users UserYanRol[]
}

// Kullanıcı ↔ Yan Rol çoklu ilişki (join tablo).
model UserYanRol {
  id       String @id @default(cuid())
  userId   String
  yanRolId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  yanRol   YanRol @relation(fields: [yanRolId], references: [id], onDelete: Cascade)

  @@unique([userId, yanRolId])
  @@index([userId])
}

model Bolge {
  id        String   @id @default(cuid())
  no        Int      @unique
  ad        String
  createdAt DateTime @default(now())

  iller       Il[]
  assignments RoleAssignment[]
  hedefler    BolgeHedef[]
  genclikHedefler GenclikBolgeHedef[]
}

model Il {
  id        String   @id @default(cuid())
  ad        String
  bolgeId   String
  createdAt DateTime @default(now())

  // Barınma muafiyeti (il-bazlı, kalıcı): il eğitimcisi "ilimizde ev/apart/yurt yoktur"
  // işaretleyince true. Ev/Apart/Yurt sayfasından yönetilir; bölge "ev/apart/yurt yok" görür.
  barinmaYok Boolean @default(false)

  bolge          Bolge            @relation(fields: [bolgeId], references: [id])
  assignments    RoleAssignment[]
  activities     Activity[]
  housingUnits   HousingUnit[]
  hedefler       IlHedef[]
  genclikHedefler GenclikIlHedef[]
  liseFaaliyetler LiseFaaliyet[]
  universiteFaaliyetler UniversiteFaaliyet[]

  @@index([bolgeId])
}

model RoleAssignment {
  id        String           @id @default(cuid())
  userId    String
  role      Role
  bolgeId   String?
  ilId      String?
  status    AssignmentStatus @default(AKTIF)
  startedAt DateTime         @default(now())
  endedAt   DateTime?
  endedById String?
  note      String?

  user  User   @relation(fields: [userId], references: [id])
  bolge Bolge? @relation(fields: [bolgeId], references: [id])
  il    Il?    @relation(fields: [ilId], references: [id])

  @@index([userId])
  @@index([ilId, status])
  @@index([bolgeId, status])
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique @default(cuid())
  role        Role
  bolgeId     String?
  ilId        String?
  invitedById String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([email])
  @@index([expiresAt])
}

model Activity {
  id    String @id @default(cuid())
  ilId  String
  yil   Int
  donem Donem

  // İlköğretim
  ik_toplamDergah          Int @default(0)
  ik_kursuYapilanDergah    Int @default(0)
  ik_egitmenSayisi         Int @default(0)
  ik_egitmenYardimciSayisi Int @default(0)
  ik_elifBaOgrenci         Int @default(0)
  ik_kuranOgrenci          Int @default(0)
  ik_gecisOgrenci          Int @default(0)

  // Lise (Eğitimci panelindeki "Lise" birimi sekmesi)
  ls_toplamDergah        Int @default(0)
  ls_liseliOgrenciSayisi Int @default(0) // Toplam liseli öğrenci sayısı
  ls_yeniIntisap         Int @default(0) // Toplam yeni intisap eden öğrenci
  ls_kafileSayisi        Int @default(0) // Toplam kafile sayısı
  ls_kafileOgrenci       Int @default(0) // Kafilelere katılan toplam öğrenci
  // Yeni yapı (faaliyet-türü bazlı; Lise Gençlik modülüyle ölçüm uyumu için)
  ls_ilimSohbetDergah    Int @default(0) // İlim/Sohbet faaliyeti yapılan dergâh
  ls_mezunOgrenci        Int @default(0) // Bu yıl mezun olacak liseli öğrenci
  ls_ilimSohbetSayisi    Int @default(0)
  ls_ilimSohbetKatilim   Int @default(0)
  ls_sosyalSayisi        Int @default(0)
  ls_sosyalKatilim       Int @default(0)
  ls_sorumlulukSayisi    Int @default(0)
  ls_sorumlulukKatilim   Int @default(0)
  ls_muhabbetSayisi      Int @default(0)
  ls_muhabbetKatilim     Int @default(0)
  ls_namazSayisi         Int @default(0)
  ls_namazKatilim        Int @default(0)
  // Eski alanlar (yeni Lise sekmesinde gösterilmiyor; veri korunur)
  ls_ilimDersYeri        Int @default(0)
  ls_ilimDersKatilim     Int @default(0)
  ls_sabahNamaziSayisi   Int @default(0)
  ls_sabahNamaziKatilim  Int @default(0)
  ls_toplamFaaliyet      Int @default(0)

  // Üniversite (Eğitimci panelindeki "Üniversite Birimi" sekmesi)
  uni_toplamDergah              Int @default(0)
  uni_universiteliOgrenciSayisi Int @default(0) // Toplam üniversite öğrenci sayısı
  uni_yeniIntisap               Int @default(0) // Toplam yeni intisap eden öğrenci
  uni_kafileSayisi              Int @default(0) // Toplam kafile sayısı
  uni_kafileOgrenci             Int @default(0) // Kafilelere katılan toplam öğrenci
  uni_kykBulusmaSayisi          Int @default(0) // Toplam KYK buluşması sayısı
  uni_kykKatilim                Int @default(0) // KYK buluşmalarına katılan
  // Yeni yapı (faaliyet-türü bazlı; Üniversite Gençlik modülüyle ölçüm uyumu için)
  uni_ilimSohbetDergah  Int @default(0) // İlim/Sohbet faaliyeti yapılan dergâh
  uni_sonSinifOgrenci   Int @default(0) // Son sınıf üniversite öğrenci
  uni_aktifKulup        Int @default(0) // Aktif kulüp sayısı
  uni_ilimSohbetSayisi  Int @default(0)
  uni_ilimSohbetKatilim Int @default(0)
  uni_kulupSayisi       Int @default(0)
  uni_kulupKatilim      Int @default(0)
  uni_sosyalSayisi      Int @default(0)
  uni_sosyalKatilim     Int @default(0)
  uni_sorumlulukSayisi  Int @default(0)
  uni_sorumlulukKatilim Int @default(0)
  uni_muhabbetSayisi    Int @default(0)
  uni_muhabbetKatilim   Int @default(0)
  uni_namazSayisi       Int @default(0)
  uni_namazKatilim      Int @default(0)
  // Eski alanlar (yeni Üniversite sekmesinde gösterilmiyor; veri korunur)
  uni_ilimDersYeri      Int @default(0)
  uni_ilimDersKatilim   Int @default(0)
  uni_sabahNamaziSayisi Int @default(0)
  uni_sabahNamaziKatilim Int @default(0)
  uni_toplamFaaliyet    Int @default(0)

  // Ortak Faaliyet (Lise + Üniversite birlikte — çift sayım önleme)
  ortakKafileSayisi           Int @default(0)
  ortakKafileLiseKatilim      Int @default(0)
  ortakKafileUniKatilim       Int @default(0)
  ortakSabahNamaziSayisi      Int @default(0)
  ortakSabahNamaziLiseKatilim Int @default(0)
  ortakSabahNamaziUniKatilim  Int @default(0)

  // Ev/Apart/Yurt
  eay_mevcutEv      Int @default(0)
  eay_mevcutApart   Int @default(0)
  eay_mevcutYurt    Int @default(0)
  eay_acilacakEv    Int @default(0)
  eay_acilacakApart Int @default(0)
  eay_acilacakYurt  Int @default(0)
  eay_kapanacakEv   Int @default(0)
  eay_kapanacakApart Int @default(0)
  eay_kapanacakYurt  Int @default(0)
  eay_bursBalan     Int @default(0)
  eay_iliskiKesme   Int @default(0)
  eay_toplamZiyaret Int @default(0)

  // Birim muafiyeti: il eğitimcisi "ilimizde bu birim çalışması/barınma yoktur" işaretleyince true.
  // Toggle (geri alınabilir). Bölge eğitimcisi "veri girilmedi" ile "çalışma yok"u ayırt etsin diye.
  muafIlkogretim Boolean @default(false)
  muafLise       Boolean @default(false)
  muafUniversite Boolean @default(false)
  muafBarinma    Boolean @default(false) // KULLANIMDIŞI: barınma muafiyeti artık il-bazlı (Il.barinmaYok)

  // Arşiv: geçmiş dönem kapatılınca true → salt-okunur (veri asla silinmez)
  arsivlendi Boolean @default(false)

  // Değişmez audit alanları
  createdById      String
  createdByName    String
  createdByRole    Role
  createdByIlId    String?
  createdByBolgeId String?
  createdAt        DateTime @default(now())

  updatedById   String?
  updatedByName String?
  updatedAt     DateTime @updatedAt

  il        Il    @relation(fields: [ilId], references: [id])
  createdBy User  @relation("CreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("UpdatedBy", fields: [updatedById], references: [id])

  @@unique([ilId, yil, donem])
  @@index([ilId])
  @@index([yil, donem])
}

// ── Lise Gençlik — Faaliyet Bazlı Kayıt ────────────────────────
// Lise Gençlik sistemi (User.sistem = LISE) il sorumluları her faaliyeti tek tek
// kaydeder; raporlar bu kayıtlardan otomatik toplanır. Eğitimci sisteminden bağımsız.
enum LiseKategori {
  ILIM_SOHBET
  SOSYAL
  SOSYAL_SORUMLULUK
  MUHABBET
  NAMAZ
  KAFILE
  DIGER
}

model LiseFaaliyet {
  id            String       @id @default(cuid())
  ilId          String
  tarih         DateTime
  yil           Int          // tarih'ten türetilir (raporlama filtresi)
  donem         Donem        @default(DONEM_1) // kullanıcı seçer (yıl+dönem filtresi)
  kategori      LiseKategori
  faaliyetAdi   String       // kategori listesinden veya "Diğer"de manuel
  aciklama      String?
  yer           String?
  katilimci     Int          @default(0)
  ilkKezKatilan Int          @default(0)
  yeniIntisap   Int          @default(0)

  // Opsiyonel foto + dosya eki (lib/storage; /api/lise-dosya/{id} ile servis)
  // url: blob mutlak URL (yerelde boş, key ile stream edilir)
  fotoKey    String?
  fotoUrl    String?
  fotoMime   String?
  dosyaKey   String?
  dosyaUrl   String?
  dosyaMime  String?
  dosyaAd    String?
  dosyaBoyut Int?

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  il Il @relation(fields: [ilId], references: [id])

  @@index([ilId, yil, donem])
  @@index([ilId, tarih])
  @@index([kategori])
}

// ── Üniversite Gençlik — Faaliyet Bazlı Kayıt ──────────────────
// Üniversite Gençlik sistemi (User.sistem = UNIVERSITE) il sorumluları her faaliyeti
// tek tek kaydeder; raporlar otomatik toplanır. Eğitimci/Lise sisteminden bağımsız.
enum UniversiteKategori {
  ILIM_SOHBET
  KULUP
  SOSYAL
  SOSYAL_SORUMLULUK
  MUHABBET
  NAMAZ
  KAFILE
  KYK
  DIGER
}

model UniversiteFaaliyet {
  id            String             @id @default(cuid())
  ilId          String
  tarih         DateTime
  yil           Int
  donem         Donem              @default(DONEM_1)
  kategori      UniversiteKategori
  faaliyetAdi   String
  aciklama      String?
  yer           String?
  katilimci     Int                @default(0)
  ilkKezKatilan Int                @default(0)
  yeniIntisap   Int                @default(0)

  fotoKey    String?
  fotoUrl    String?
  fotoMime   String?
  dosyaKey   String?
  dosyaUrl   String?
  dosyaMime  String?
  dosyaAd    String?
  dosyaBoyut Int?

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  il Il @relation(fields: [ilId], references: [id])

  @@index([ilId, yil, donem])
  @@index([ilId, tarih])
  @@index([kategori])
}

// ── Faaliyet Yapılandırma Merkezi (Faz 1) ──────────────────────
// Koddan bağımsız yönetim. Eklemeli: mevcut Activity/LiseFaaliyet/UniversiteFaaliyet
// ve raporlar DEĞİŞMEZ. Kayıt yoksa varsayılan = açık/görünür → mevcut davranış korunur.

/** Bir (sistem, yıl, dönem) için veri girişi kilidi. Satır yoksa giriş AÇIKtır. */
model DonemAyar {
  id             String    @id @default(cuid())
  sistem         Sistem
  yil            Int
  donem          Donem
  veriGirisiAcik Boolean   @default(true)
  baslangic      DateTime?
  bitis          DateTime?
  aciklama       String?

  guncelleyenId String?
  guncelleyenAd String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sistem, yil, donem])
  @@index([sistem, yil])
}

/** Bir sistemdeki bir alanın görünürlük/zorunluluk ayarı.
 *  alanKodu = Activity kolon adı (ör. "ls_yeniIntisap") — değişmez sistem kimliği.
 *  Satır yoksa alan: görünür + opsiyonel + aktif (mevcut davranış). */
model AlanAyar {
  id       String  @id @default(cuid())
  sistem   Sistem
  alanKodu String
  gorunur  Boolean @default(true)
  zorunlu  Boolean @default(false)
  aktif    Boolean @default(true)
  sira     Int     @default(0)

  guncelleyenId String?
  guncelleyenAd String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sistem, alanKodu])
  @@index([sistem])
}

// ── Barınma Birimleri ──────────────────────────────────────────
model HousingUnit {
  id        String   @id @default(cuid())
  ilId      String
  tip       String   // "EV" | "APART" | "YURT"
  ad        String
  konum     String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())

  il         Il               @relation(fields: [ilId], references: [id])
  ogrenciler HousingStudent[]
  ziyaretler HousingVisit[]

  @@index([ilId, tip])
}

model HousingStudent {
  id             String   @id @default(cuid())
  housingUnitId  String
  adSoyad        String
  bolum          String?
  sinif          String?
  bursMu         Boolean  @default(false)
  disiplinSayisi Int      @default(0)
  iliskiKesme    Boolean  @default(false)
  notlar         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  housingUnit HousingUnit @relation(fields: [housingUnitId], references: [id], onDelete: Cascade)

  @@index([housingUnitId])
}

model HousingVisit {
  id            String   @id @default(cuid())
  housingUnitId String
  tarih         DateTime
  ziyaretEden   String
  notlar        String?
  createdAt     DateTime @default(now())

  housingUnit HousingUnit @relation(fields: [housingUnitId], references: [id], onDelete: Cascade)

  @@index([housingUnitId])
  @@index([tarih])
}

// ── Hedef Yönetimi ──────────────────────────────────────────────

// Genel Merkez tarafından bölgeye verilen hedefler
model BolgeHedef {
  id      String @id @default(cuid())
  bolgeId String
  yil     Int
  donem   Donem

  yeniIntisap    Int @default(0)
  sosyalFaaliyet Int @default(0)
  kafile         Int @default(0)
  sabahNamazi    Int @default(0)
  ilimDersi      Int @default(0)
  kykBulusma     Int @default(0)
  ziyaret        Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bolge   Bolge     @relation(fields: [bolgeId], references: [id])
  ilHedef IlHedef[]

  @@unique([bolgeId, yil, donem])
  @@index([yil, donem])
}

// Bölge sorumlusu tarafından ile verilen hedefler
model IlHedef {
  id           String @id @default(cuid())
  ilId         String
  bolgeHedefId String
  yil          Int
  donem        Donem

  yeniIntisap    Int @default(0)
  sosyalFaaliyet Int @default(0)
  kafile         Int @default(0)
  sabahNamazi    Int @default(0)
  ilimDersi      Int @default(0)
  kykBulusma     Int @default(0)
  ziyaret        Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  il         Il         @relation(fields: [ilId], references: [id])
  bolgeHedef BolgeHedef @relation(fields: [bolgeHedefId], references: [id], onDelete: Cascade)

  @@unique([ilId, yil, donem])
  @@index([ilId])
}

// ── Gençlik (Üniversite / Lise) Muradımız hedefleri ──────────────────────
// Eğitimci hedeflerinden ayrı; kategori-bazlı (faaliyet kategorisi → hedef sayı).
// hedefler Json: { "ILIM_SOHBET": 10, "SOSYAL": 5, ..., "YENI_INTISAP": 3 }
model GenclikBolgeHedef {
  id        String   @id @default(cuid())
  sistem    Sistem   // UNIVERSITE | LISE
  bolgeId   String
  yil       Int
  donem     Donem
  hedefler  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bolge Bolge @relation(fields: [bolgeId], references: [id])

  @@unique([sistem, bolgeId, yil, donem])
  @@index([sistem, yil, donem])
}

model GenclikIlHedef {
  id        String   @id @default(cuid())
  sistem    Sistem   // UNIVERSITE | LISE
  ilId      String
  yil       Int
  donem     Donem
  hedefler  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  il Il @relation(fields: [ilId], references: [id])

  @@unique([sistem, ilId, yil, donem])
  @@index([sistem, yil, donem])
}

// ── Gönüllü Sistemi ────────────────────────────────────────────

enum OgrenimDurum {
  ILKOKUL
  ORTAOKUL
  LISE
  UNIVERSITE
}

enum OgrenimTuru {
  ONLISANS
  LISANS
  YUKSEK_LISANS
  DOKTORA
}

enum BursBasvuruDurum {
  BEKLEMEDE
  INCELENIYOR
  GORUSULDU
  ONAYLANDI
  REDDEDILDI
}

enum GeriBildirimKonu {
  ONERI
  TALEP
  TEKNIK_SORUN
  DIGER
}

enum GeriBildirimDurum {
  YENI
  INCELENIYOR
  COZULDU
  KAPATILDI
}

model Volunteer {
  id            String       @id @default(cuid())
  adSoyad       String
  telefon       String       @unique
  email         String?      @unique
  emailVerified DateTime?
  passwordHash  String
  ogrenim       OgrenimDurum
  ogrenimTuru   OgrenimTuru?
  bolum         String?
  okul          String?
  il            String?
  // SerGenç ana rol (başvuruda seçilir): "UNIVERSITE" | "LISE"
  serGencRol    String?
  // Yan rol: Barınma — evlerimizde/yurtlarımızda kalan öğrenci (yetkili işaretler)
  barinma       Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  bursBasvurulari  BursBasvuru[]
  ekKayitBasvurulari EkKayitBasvuru[]
  geriBildirimler  GeriBildirim[]
}

model BursBasvuru {
  id           String           @id @default(cuid())
  volunteerId  String
  adSoyad      String
  telefon      String
  email        String?
  universite   String
  fakulteBolum String
  sinif        String
  il           String
  madiDurum    String
  aciklama     String
  belgeler     String[]
  durum        BursBasvuruDurum @default(BEKLEMEDE)
  yoneticiNotu String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@index([durum])
  @@index([createdAt])
}

model EkKayitBasvuru {
  id               String           @id @default(cuid())
  volunteerId      String
  ogrenciAd        String
  ogrenciSoyad     String
  telefon          String
  geldigiUlke      String?
  geldigiIl        String?
  geldigiIlce      String?
  gidecegiBolge    String?
  gidecegiIl       String?
  gidecegiIlce     String?
  universite       String
  fakulte          String
  bolum            String
  kayitTipi        String
  veliAdSoyad      String?
  veliTelefon      String?
  referansAdSoyad  String?
  referansTelefon  String?
  referansGorev    String?
  durum            BursBasvuruDurum @default(BEKLEMEDE)
  yoneticiNotu     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@index([durum])
  @@index([createdAt])
}

model GeriBildirim {
  id          String            @id @default(cuid())
  volunteerId String
  konu        GeriBildirimKonu
  mesaj       String
  durum       GeriBildirimDurum @default(YENI)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@index([durum])
  @@index([createdAt])
}

// ── Doküman Merkezi (Drive benzeri klasör/dosya yönetimi) ──────

model DokumanKlasor {
  id       String  @id @default(cuid())
  ad       String
  parentId String?

  // Hedef kitle erişimi — false ise yalnızca yönetici görür
  erisimEgitim     Boolean @default(false)
  erisimUniversite Boolean @default(false)
  erisimLise       Boolean @default(false)
  erisimGonullu    Boolean @default(false)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent     DokumanKlasor?  @relation("KlasorHiyerarsi", fields: [parentId], references: [id])
  children   DokumanKlasor[] @relation("KlasorHiyerarsi")
  dokumanlar Dokuman[]
  paylasimlar DokumanPaylasim[]

  @@index([parentId])
}

model Dokuman {
  id       String  @id @default(cuid())
  ad       String
  klasorId String?
  /** Blob URL'i (Vercel Blob) veya local sürücüde /api/dosya/{id} */
  url      String
  /** Depolama anahtarı — silme işlemi için (blob pathname / local dosya adı) */
  storageKey String
  boyut    Int
  mimeTipi String
  uzanti   String
  /** Sürüm sayacı — yeni sürüm yüklendikçe artar (güncelleme takibi) */
  surum    Int     @default(1)

  erisimEgitim     Boolean @default(false)
  erisimUniversite Boolean @default(false)
  erisimLise       Boolean @default(false)
  erisimGonullu    Boolean @default(false)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  klasor      DokumanKlasor?    @relation(fields: [klasorId], references: [id])
  paylasimlar DokumanPaylasim[]

  @@index([klasorId])
}

/** Üyeliksiz görüntüleme için paylaşım linki (klasör VEYA dosya) */
model DokumanPaylasim {
  id          String    @id @default(cuid())
  token       String    @unique
  klasorId    String?
  dokumanId   String?
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  klasor  DokumanKlasor? @relation(fields: [klasorId], references: [id], onDelete: Cascade)
  dokuman Dokuman?       @relation(fields: [dokumanId], references: [id], onDelete: Cascade)
}

// ── Dinamik Form Yönetimi ──────────────────────────────────────

enum SoruTipi {
  KISA_METIN
  UZUN_METIN
  SAYI
  TARIH
  TEK_SECIM
  COKLU_SECIM
  DOSYA
  // ── Veri Toplama Merkezi geliştirmesi (eklemeli; mevcut tipler dokunulmadı) ──
  SAAT
  TELEFON
  EPOSTA
  ACILIR_LISTE
  EVET_HAYIR
  BOLUM // bölüm başlığı/açıklaması — cevap toplamaz, sadece gruplar
}

enum FormDurum {
  TASLAK
  YAYINDA
  KAPALI
  PASIF // Arşiv geliştirmesi (Faz 8) — eklemeli
  ARSIV
}

enum SutunTipi {
  METIN
  SAYI
  TARIH
  SECIM
  DOSYA
}

enum SablonTur {
  FORM
  VERI_TABLOSU
}

model DinamikForm {
  id       String    @id @default(cuid())
  baslik   String
  aciklama String?
  durum    FormDurum @default(TASLAK)

  // Görünürlük: hangi roller + hangi sistemler
  hedefBolge       Boolean @default(false)
  hedefIl          Boolean @default(false)
  sistemEgitim     Boolean @default(false)
  sistemUniversite Boolean @default(false)
  sistemLise       Boolean @default(false)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sorular  FormSoru[]
  yanitlar FormYanit[]

  @@index([durum])
}

model FormSoru {
  id         String   @id @default(cuid())
  formId     String
  sira       Int
  etiket     String
  tip        SoruTipi
  zorunlu    Boolean  @default(false)
  /** TEK_SECIM / COKLU_SECIM / ACILIR_LISTE için seçenekler */
  secenekler String[]

  // ── Veri Toplama Merkezi geliştirmesi (hepsi nullable; eski sorular etkilenmez) ──
  /** Bölüm/soru altı açıklama metni (BOLUM tipinde bölüm açıklaması) */
  aciklama    String?
  /** Koşullu görünürlük: bu sorunun bağlı olduğu sorunun id'si (null = her zaman görünür) */
  kosulSoruId String?
  /** Koşul: kosulSoruId'li sorunun cevabı bu değere eşit/içeriyorsa bu soru görünür */
  kosulDeger  String?

  form DinamikForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, sira])
}

model FormYanit {
  id       String @id @default(cuid())
  formId   String
  userId   String
  userName String
  /** { [soruId]: string | string[] | number | { dosyaId, ad, url } } */
  cevaplar Json
  createdAt DateTime @default(now())

  form DinamikForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, userId])
  @@index([formId])
}

/** Form yanıtlarındaki dosya yüklemeleri (Doküman Merkezi'nden bağımsız) */
model FormYanitDosya {
  id         String   @id @default(cuid())
  ad         String
  storageKey String
  url        String
  mimeTipi   String
  boyut      Int
  yukleyenId String
  createdAt  DateTime @default(now())
}

// ── Veri Toplama Merkezi: Veri Tabloları + Şablonlar ───────────
// (Form sistemine dokunmadan, tamamen ayrı modeller)

/** Değişken sayıda satır toplanan veri tablosu (ör. "Üniversiteye Yerleşen Mezunlar") */
model VeriTablosu {
  id       String    @id @default(cuid())
  baslik   String
  aciklama String?
  durum    FormDurum @default(TASLAK)

  // Görünürlük — DinamikForm ile aynı model
  hedefBolge       Boolean @default(false)
  hedefIl          Boolean @default(false)
  sistemEgitim     Boolean @default(false)
  sistemUniversite Boolean @default(false)
  sistemLise       Boolean @default(false)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sutunlar VeriTabloSutun[]
  kayitlar VeriTabloKayit[]

  @@index([durum])
}

model VeriTabloSutun {
  id         String    @id @default(cuid())
  tabloId    String
  sira       Int
  baslik     String
  tip        SutunTipi @default(METIN)
  zorunlu    Boolean   @default(false)
  /** SECIM tipi için seçenekler */
  secenekler String[]

  tablo VeriTablosu @relation(fields: [tabloId], references: [id], onDelete: Cascade)

  @@index([tabloId, sira])
}

/** Bir kullanıcının (il/bölge sorumlusu) girdiği TEK satır — sınırsız satır = çok kayıt */
model VeriTabloKayit {
  id       String @id @default(cuid())
  tabloId  String
  userId   String
  userName String
  /** { [sutunId]: string | number | { dosyaId, ad, url } } */
  degerler  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tablo VeriTablosu @relation(fields: [tabloId], references: [id], onDelete: Cascade)

  @@index([tabloId])
  @@index([userId])
}

/** Hazır veri toplama şablonu (Form veya Veri Tablosu iskeleti) */
model Sablon {
  id       String    @id @default(cuid())
  ad       String
  aciklama String?
  tur      SablonTur @default(FORM)
  /** FORM → { sorular: [...] } | VERI_TABLOSU → { sutunlar: [...] } */
  icerik   Json

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tur])
}

// ── Duyuru & Bildirim Merkezi ──────────────────────────────────

enum BildirimTipi {
  DUYURU
  BILGILENDIRME
  DOSYA
  FORM
}

model Bildirim {
  id     String       @id @default(cuid())
  baslik String
  mesaj  String
  tip    BildirimTipi @default(DUYURU)
  /** Tıklanınca gidilecek sayfa (ör. /panel/formlarim/abc) */
  link   String?

  // Hedef kitle
  hedefBolge       Boolean @default(false)
  hedefIl          Boolean @default(false)
  hedefGonullu     Boolean @default(false)
  sistemEgitim     Boolean @default(false)
  sistemUniversite Boolean @default(false)
  sistemLise       Boolean @default(false)

  // Kanallar (SMS/WhatsApp sağlayıcı bağlanınca açılacak)
  kanalEposta      Boolean @default(false)
  epostaGonderilen Int     @default(0)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())

  alimlar BildirimAlim[]

  @@index([createdAt])
}

/** Alıcı başına teslim + görüldü kaydı */
model BildirimAlim {
  id          String    @id @default(cuid())
  bildirimId  String
  userId      String?
  volunteerId String?
  aliciAd     String
  goruldu     DateTime?

  bildirim Bildirim @relation(fields: [bildirimId], references: [id], onDelete: Cascade)

  @@unique([bildirimId, userId])
  @@unique([bildirimId, volunteerId])
  @@index([userId, goruldu])
  @@index([volunteerId, goruldu])
}

// ── Duyuru Panosu (üst bant) ──────────────────────────────────

/** Tüm panellerin üstünde, süre boyunca kayan sabit duyuru bandı */
model Duyuru {
  id        String   @id @default(cuid())
  metin     String
  /** Tıklanınca gidilecek sayfa (opsiyonel) */
  link      String?
  baslangic DateTime
  bitis     DateTime
  aktif     Boolean  @default(true)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([aktif, baslangic, bitis])
}

// ── Pop-Up Yönetimi ──────────────────────────────────────────

enum PopupGosterim {
  TEK_SEFER     // kullanıcıya sadece 1 kez göster
  HER_GIRIS     // her girişte göster
  SUREKLI       // sürekli göster (kapatana kadar her sayfada)
  TARIH_ARALIGI // yalnızca başlangıç–bitiş arasında göster
}

model Popup {
  id        String        @id @default(cuid())
  baslik    String
  aciklama  String
  gorselUrl String?
  gorselKey String?
  /** "Detay Gör" yönlendirme linki */
  link      String?
  gosterim  PopupGosterim @default(HER_GIRIS)
  baslangic DateTime
  bitis     DateTime
  aktif     Boolean       @default(true)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gorulmeler PopupGorulme[]

  @@index([aktif, baslangic, bitis])
}

/** Pop-up'ın kullanıcı bazında görülme kaydı (TEK_SEFER için, cihaz bağımsız) */
model PopupGorulme {
  id          String   @id @default(cuid())
  popupId     String
  userId      String?
  volunteerId String?
  goruldu     DateTime @default(now())

  popup Popup @relation(fields: [popupId], references: [id], onDelete: Cascade)

  @@unique([popupId, userId])
  @@unique([popupId, volunteerId])
  @@index([popupId])
}

// ── Kimlik Doğrulama Token'ları (şifre sıfırlama + e-posta doğrulama) ──

enum AuthTokenType {
  SIFRE_SIFIRLAMA_USER
  SIFRE_SIFIRLAMA_VOLUNTEER
  EPOSTA_DOGRULAMA_VOLUNTEER
}

model AuthToken {
  id          String        @id @default(cuid())
  /** Ham token'ın SHA-256 hash'i — ham değer yalnızca e-posta linkinde bulunur */
  tokenHash   String        @unique
  type        AuthTokenType
  userId      String?
  volunteerId String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime      @default(now())

  @@index([userId, type])
  @@index([volunteerId, type])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  description String?
  createdAt   DateTime @default(now())

  user User @relation("ActionBy", fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ── İstişare Merkezi (kurumsal talep / yazışma) ──────────────────────────
model Talep {
  id          String     @id @default(cuid())
  baslik      String
  birim       TalepBirim
  durum       TalepDurum @default(YENI)
  sistem      Sistem     // oluşturanın sistemi (yönlendirme + filtre)
  olusturanId String
  sonMesajAt  DateTime   @default(now()) // listeleme sıralaması
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  olusturan User         @relation("TalepOlusturan", fields: [olusturanId], references: [id])
  mesajlar  TalepMesaj[]

  @@index([durum])
  @@index([birim])
  @@index([olusturanId])
  @@index([sonMesajAt])
  @@index([sistem])
}

model TalepMesaj {
  id         String   @id @default(cuid())
  talepId    String
  gonderenId String
  mesaj      String
  dosyalar   String[] // yüklenen dosya URL'leri (belge + ek)
  createdAt  DateTime @default(now())

  talep    Talep @relation(fields: [talepId], references: [id], onDelete: Cascade)
  gonderen User  @relation("TalepMesajGonderen", fields: [gonderenId], references: [id])

  @@index([talepId])
}
