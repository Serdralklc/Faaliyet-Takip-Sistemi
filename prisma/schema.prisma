generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SISTEM_ADMIN
  GENEL_MERKEZ
  TURKIYE_EGITIM_SORUMLUSU
  TURKIYE_UNIVERSITE_SORUMLUSU
  TURKIYE_LISE_SORUMLUSU
  BOLGE_SORUMLUSU
  IL_SORUMLUSU
  BEKLEYEN
}

enum UserStatus {
  AKTIF
  BEKLEMEDE
  PASIF
}

enum AssignmentStatus {
  AKTIF
  TAMAMLANDI
}

enum Donem {
  DONEM_1
  DONEM_2
  YAZ_DONEMI
}

// Her kullanıcı hangi faaliyet takip sistemine ait olduğunu belirtir.
// Farklı sistemlere kayıtlı kullanıcılar birbirinin verilerini göremez.
enum Sistem {
  EGITIMCI   // Eğitimci Kadrosu — il/bölge sorumluları, yöneticiler
  UNIVERSITE // Üniversite Gençlik faaliyet takip sistemi
  LISE       // Lise Gençlik faaliyet takip sistemi
}

model User {
  id           String     @id @default(cuid())
  ad           String
  soyad        String
  email        String     @unique
  telefon      String?
  passwordHash String?
  role         Role       @default(BEKLEYEN)
  status       UserStatus @default(BEKLEMEDE)
  sistem       Sistem     @default(EGITIMCI)
  // Kayıt sırasında başvurulan görev bilgisi (onay sürecinde admin görsün)
  basvuruGorev   String?
  basvuruBolgeId String?
  basvuruIlId    String?
  // Son giriş (aktiflik) zamanı — her başarılı girişte güncellenir
  sonAktif     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignments       RoleAssignment[]
  createdActivities Activity[]       @relation("CreatedBy")
  updatedActivities Activity[]       @relation("UpdatedBy")
  auditLogs         AuditLog[]       @relation("ActionBy")
  invitations       Invitation[]     @relation("InvitedBy")
}

model Bolge {
  id        String   @id @default(cuid())
  no        Int      @unique
  ad        String
  createdAt DateTime @default(now())

  iller       Il[]
  assignments RoleAssignment[]
  hedefler    BolgeHedef[]
}

model Il {
  id        String   @id @default(cuid())
  ad        String
  bolgeId   String
  createdAt DateTime @default(now())

  bolge        Bolge            @relation(fields: [bolgeId], references: [id])
  assignments  RoleAssignment[]
  activities   Activity[]
  housingUnits HousingUnit[]
  hedefler     IlHedef[]
}

model RoleAssignment {
  id        String           @id @default(cuid())
  userId    String
  role      Role
  bolgeId   String?
  ilId      String?
  status    AssignmentStatus @default(AKTIF)
  startedAt DateTime         @default(now())
  endedAt   DateTime?
  endedById String?
  note      String?

  user  User   @relation(fields: [userId], references: [id])
  bolge Bolge? @relation(fields: [bolgeId], references: [id])
  il    Il?    @relation(fields: [ilId], references: [id])

  @@index([userId])
  @@index([ilId, status])
  @@index([bolgeId, status])
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique @default(cuid())
  role        Role
  bolgeId     String?
  ilId        String?
  invitedById String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id])
}

model Activity {
  id    String @id @default(cuid())
  ilId  String
  yil   Int
  donem Donem

  // İlköğretim
  ik_toplamDergah          Int @default(0)
  ik_kursuYapilanDergah    Int @default(0)
  ik_egitmenSayisi         Int @default(0)
  ik_egitmenYardimciSayisi Int @default(0)
  ik_elifBaOgrenci         Int @default(0)
  ik_kuranOgrenci          Int @default(0)
  ik_gecisOgrenci          Int @default(0)

  // Lise
  ls_toplamDergah       Int @default(0)
  ls_ilimDersYeri       Int @default(0)
  ls_ilimDersKatilim    Int @default(0)
  ls_sabahNamaziSayisi  Int @default(0)
  ls_sabahNamaziKatilim Int @default(0)
  ls_kafileSayisi       Int @default(0)
  ls_kafileOgrenci      Int @default(0)
  ls_toplamFaaliyet     Int @default(0)
  ls_yeniIntisap        Int @default(0)

  // Üniversite
  uni_toplamDergah      Int @default(0)
  uni_ilimDersYeri      Int @default(0)
  uni_ilimDersKatilim   Int @default(0)
  uni_sabahNamaziSayisi Int @default(0)
  uni_sabahNamaziKatilim Int @default(0)
  uni_kafileSayisi      Int @default(0)
  uni_kafileOgrenci     Int @default(0)
  uni_toplamFaaliyet    Int @default(0)
  uni_kykBulusmaSayisi  Int @default(0)
  uni_kykKatilim        Int @default(0)
  uni_yeniIntisap       Int @default(0)

  // Ortak Faaliyet (Lise + Üniversite birlikte — çift sayım önleme)
  ortakKafileSayisi           Int @default(0)
  ortakKafileLiseKatilim      Int @default(0)
  ortakKafileUniKatilim       Int @default(0)
  ortakSabahNamaziSayisi      Int @default(0)
  ortakSabahNamaziLiseKatilim Int @default(0)
  ortakSabahNamaziUniKatilim  Int @default(0)

  // Ev/Apart/Yurt
  eay_mevcutEv      Int @default(0)
  eay_mevcutApart   Int @default(0)
  eay_mevcutYurt    Int @default(0)
  eay_acilacakEv    Int @default(0)
  eay_acilacakApart Int @default(0)
  eay_acilacakYurt  Int @default(0)
  eay_kapanacakEv   Int @default(0)
  eay_kapanacakApart Int @default(0)
  eay_kapanacakYurt  Int @default(0)
  eay_bursBalan     Int @default(0)
  eay_iliskiKesme   Int @default(0)
  eay_toplamZiyaret Int @default(0)

  // Arşiv: geçmiş dönem kapatılınca true → salt-okunur (veri asla silinmez)
  arsivlendi Boolean @default(false)

  // Değişmez audit alanları
  createdById      String
  createdByName    String
  createdByRole    Role
  createdByIlId    String?
  createdByBolgeId String?
  createdAt        DateTime @default(now())

  updatedById   String?
  updatedByName String?
  updatedAt     DateTime @updatedAt

  il        Il    @relation(fields: [ilId], references: [id])
  createdBy User  @relation("CreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("UpdatedBy", fields: [updatedById], references: [id])

  @@unique([ilId, yil, donem])
  @@index([ilId])
  @@index([yil, donem])
}

// ── Barınma Birimleri ──────────────────────────────────────────
model HousingUnit {
  id        String   @id @default(cuid())
  ilId      String
  tip       String   // "EV" | "APART" | "YURT"
  ad        String
  konum     String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())

  il         Il               @relation(fields: [ilId], references: [id])
  ogrenciler HousingStudent[]
  ziyaretler HousingVisit[]

  @@index([ilId, tip])
}

model HousingStudent {
  id             String   @id @default(cuid())
  housingUnitId  String
  adSoyad        String
  bolum          String?
  sinif          String?
  bursMu         Boolean  @default(false)
  disiplinSayisi Int      @default(0)
  iliskiKesme    Boolean  @default(false)
  notlar         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  housingUnit HousingUnit @relation(fields: [housingUnitId], references: [id], onDelete: Cascade)

  @@index([housingUnitId])
}

model HousingVisit {
  id            String   @id @default(cuid())
  housingUnitId String
  tarih         DateTime
  ziyaretEden   String
  notlar        String?
  createdAt     DateTime @default(now())

  housingUnit HousingUnit @relation(fields: [housingUnitId], references: [id], onDelete: Cascade)

  @@index([housingUnitId])
  @@index([tarih])
}

// ── Hedef Yönetimi ──────────────────────────────────────────────

// Genel Merkez tarafından bölgeye verilen hedefler
model BolgeHedef {
  id      String @id @default(cuid())
  bolgeId String
  yil     Int
  donem   String // DONEM_1 | DONEM_2 | YAZ_DONEMI

  yeniIntisap    Int @default(0)
  sosyalFaaliyet Int @default(0)
  kafile         Int @default(0)
  sabahNamazi    Int @default(0)
  ilimDersi      Int @default(0)
  kykBulusma     Int @default(0)
  ziyaret        Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bolge   Bolge     @relation(fields: [bolgeId], references: [id])
  ilHedef IlHedef[]

  @@unique([bolgeId, yil, donem])
  @@index([yil, donem])
}

// Bölge sorumlusu tarafından ile verilen hedefler
model IlHedef {
  id           String @id @default(cuid())
  ilId         String
  bolgeHedefId String
  yil          Int
  donem        String

  yeniIntisap    Int @default(0)
  sosyalFaaliyet Int @default(0)
  kafile         Int @default(0)
  sabahNamazi    Int @default(0)
  ilimDersi      Int @default(0)
  kykBulusma     Int @default(0)
  ziyaret        Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  il         Il         @relation(fields: [ilId], references: [id])
  bolgeHedef BolgeHedef @relation(fields: [bolgeHedefId], references: [id], onDelete: Cascade)

  @@unique([ilId, yil, donem])
  @@index([ilId])
}

// ── Gönüllü Sistemi ────────────────────────────────────────────

enum OgrenimDurum {
  ILKOKUL
  ORTAOKUL
  LISE
  UNIVERSITE
}

enum OgrenimTuru {
  ONLISANS
  LISANS
  YUKSEK_LISANS
  DOKTORA
}

enum BursBasvuruDurum {
  BEKLEMEDE
  INCELENIYOR
  GORUSULDU
  ONAYLANDI
  REDDEDILDI
}

enum GeriBildirimKonu {
  ONERI
  TALEP
  TEKNIK_SORUN
  DIGER
}

enum GeriBildirimDurum {
  YENI
  INCELENIYOR
  COZULDU
  KAPATILDI
}

model Volunteer {
  id            String       @id @default(cuid())
  adSoyad       String
  telefon       String       @unique
  email         String?      @unique
  emailVerified DateTime?
  passwordHash  String
  ogrenim       OgrenimDurum
  ogrenimTuru   OgrenimTuru?
  bolum         String?
  okul          String?
  il            String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  bursBasvurulari  BursBasvuru[]
  ekKayitBasvurulari EkKayitBasvuru[]
  geriBildirimler  GeriBildirim[]
}

model BursBasvuru {
  id           String           @id @default(cuid())
  volunteerId  String
  adSoyad      String
  telefon      String
  email        String?
  universite   String
  fakulteBolum String
  sinif        String
  il           String
  madiDurum    String
  aciklama     String
  belgeler     String[]
  durum        BursBasvuruDurum @default(BEKLEMEDE)
  yoneticiNotu String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@index([durum])
  @@index([createdAt])
}

model EkKayitBasvuru {
  id               String           @id @default(cuid())
  volunteerId      String
  ogrenciAd        String
  ogrenciSoyad     String
  telefon          String
  geldigiUlke      String?
  geldigiIl        String?
  geldigiIlce      String?
  gidecegiBolge    String?
  gidecegiIl       String?
  gidecegiIlce     String?
  universite       String
  fakulte          String
  bolum            String
  kayitTipi        String
  veliAdSoyad      String?
  veliTelefon      String?
  referansAdSoyad  String?
  referansTelefon  String?
  referansGorev    String?
  durum            BursBasvuruDurum @default(BEKLEMEDE)
  yoneticiNotu     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@index([durum])
  @@index([createdAt])
}

model GeriBildirim {
  id          String            @id @default(cuid())
  volunteerId String
  konu        GeriBildirimKonu
  mesaj       String
  durum       GeriBildirimDurum @default(YENI)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  volunteer Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@index([durum])
  @@index([createdAt])
}

// ── Doküman Merkezi (Drive benzeri klasör/dosya yönetimi) ──────

model DokumanKlasor {
  id       String  @id @default(cuid())
  ad       String
  parentId String?

  // Hedef kitle erişimi — false ise yalnızca yönetici görür
  erisimEgitim     Boolean @default(false)
  erisimUniversite Boolean @default(false)
  erisimLise       Boolean @default(false)
  erisimGonullu    Boolean @default(false)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent     DokumanKlasor?  @relation("KlasorHiyerarsi", fields: [parentId], references: [id])
  children   DokumanKlasor[] @relation("KlasorHiyerarsi")
  dokumanlar Dokuman[]
  paylasimlar DokumanPaylasim[]

  @@index([parentId])
}

model Dokuman {
  id       String  @id @default(cuid())
  ad       String
  klasorId String?
  /** Blob URL'i (Vercel Blob) veya local sürücüde /api/dosya/{id} */
  url      String
  /** Depolama anahtarı — silme işlemi için (blob pathname / local dosya adı) */
  storageKey String
  boyut    Int
  mimeTipi String
  uzanti   String

  erisimEgitim     Boolean @default(false)
  erisimUniversite Boolean @default(false)
  erisimLise       Boolean @default(false)
  erisimGonullu    Boolean @default(false)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  klasor      DokumanKlasor?    @relation(fields: [klasorId], references: [id])
  paylasimlar DokumanPaylasim[]

  @@index([klasorId])
}

/** Üyeliksiz görüntüleme için paylaşım linki (klasör VEYA dosya) */
model DokumanPaylasim {
  id          String    @id @default(cuid())
  token       String    @unique
  klasorId    String?
  dokumanId   String?
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  klasor  DokumanKlasor? @relation(fields: [klasorId], references: [id], onDelete: Cascade)
  dokuman Dokuman?       @relation(fields: [dokumanId], references: [id], onDelete: Cascade)
}

// ── Dinamik Form Yönetimi ──────────────────────────────────────

enum SoruTipi {
  KISA_METIN
  UZUN_METIN
  SAYI
  TARIH
  TEK_SECIM
  COKLU_SECIM
  DOSYA
}

enum FormDurum {
  TASLAK
  YAYINDA
  KAPALI
}

model DinamikForm {
  id       String    @id @default(cuid())
  baslik   String
  aciklama String?
  durum    FormDurum @default(TASLAK)

  // Görünürlük: hangi roller + hangi sistemler
  hedefBolge       Boolean @default(false)
  hedefIl          Boolean @default(false)
  sistemEgitim     Boolean @default(false)
  sistemUniversite Boolean @default(false)
  sistemLise       Boolean @default(false)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sorular  FormSoru[]
  yanitlar FormYanit[]

  @@index([durum])
}

model FormSoru {
  id         String   @id @default(cuid())
  formId     String
  sira       Int
  etiket     String
  tip        SoruTipi
  zorunlu    Boolean  @default(false)
  /** TEK_SECIM / COKLU_SECIM için seçenekler */
  secenekler String[]

  form DinamikForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, sira])
}

model FormYanit {
  id       String @id @default(cuid())
  formId   String
  userId   String
  userName String
  /** { [soruId]: string | string[] | number | { dosyaId, ad, url } } */
  cevaplar Json
  createdAt DateTime @default(now())

  form DinamikForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, userId])
  @@index([formId])
}

/** Form yanıtlarındaki dosya yüklemeleri (Doküman Merkezi'nden bağımsız) */
model FormYanitDosya {
  id         String   @id @default(cuid())
  ad         String
  storageKey String
  url        String
  mimeTipi   String
  boyut      Int
  yukleyenId String
  createdAt  DateTime @default(now())
}

// ── Duyuru & Bildirim Merkezi ──────────────────────────────────

enum BildirimTipi {
  DUYURU
  BILGILENDIRME
  DOSYA
  FORM
}

model Bildirim {
  id     String       @id @default(cuid())
  baslik String
  mesaj  String
  tip    BildirimTipi @default(DUYURU)
  /** Tıklanınca gidilecek sayfa (ör. /panel/formlarim/abc) */
  link   String?

  // Hedef kitle
  hedefBolge       Boolean @default(false)
  hedefIl          Boolean @default(false)
  hedefGonullu     Boolean @default(false)
  sistemEgitim     Boolean @default(false)
  sistemUniversite Boolean @default(false)
  sistemLise       Boolean @default(false)

  // Kanallar (SMS/WhatsApp sağlayıcı bağlanınca açılacak)
  kanalEposta      Boolean @default(false)
  epostaGonderilen Int     @default(0)

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())

  alimlar BildirimAlim[]

  @@index([createdAt])
}

/** Alıcı başına teslim + görüldü kaydı */
model BildirimAlim {
  id          String    @id @default(cuid())
  bildirimId  String
  userId      String?
  volunteerId String?
  aliciAd     String
  goruldu     DateTime?

  bildirim Bildirim @relation(fields: [bildirimId], references: [id], onDelete: Cascade)

  @@unique([bildirimId, userId])
  @@unique([bildirimId, volunteerId])
  @@index([userId, goruldu])
  @@index([volunteerId, goruldu])
}

// ── Kimlik Doğrulama Token'ları (şifre sıfırlama + e-posta doğrulama) ──

enum AuthTokenType {
  SIFRE_SIFIRLAMA_USER
  SIFRE_SIFIRLAMA_VOLUNTEER
  EPOSTA_DOGRULAMA_VOLUNTEER
}

model AuthToken {
  id          String        @id @default(cuid())
  /** Ham token'ın SHA-256 hash'i — ham değer yalnızca e-posta linkinde bulunur */
  tokenHash   String        @unique
  type        AuthTokenType
  userId      String?
  volunteerId String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime      @default(now())

  @@index([userId, type])
  @@index([volunteerId, type])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  description String?
  createdAt   DateTime @default(now())

  user User @relation("ActionBy", fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
